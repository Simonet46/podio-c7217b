# ─────────────────────────────────────────────────────────────
# PODIO — variables de entorno
# Copiá este archivo a `.env.local` y completá los valores.
# La app CORRE SIN ESTAS CLAVES usando datos sembrados localmente.
# Al completarlas, se activan Supabase (datos reales) y Stripe (pagos).
# ─────────────────────────────────────────────────────────────

# URL pública del sitio (para callbacks de Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────
# Si están vacías, la app usa el seed local (src/lib/data/seed.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo en el servidor (webhooks, escritura). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (Connect, modelo pass-through) ────────────────────
# Si están vacías, el botón de aporte corre en "modo demo" (sin cobro real).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
